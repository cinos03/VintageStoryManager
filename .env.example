# ---- Vintage Story Server Manager configuration ----

# Web UI / API port (host)
MANAGER_PORT=8080

# Secret used to sign login sessions (CHANGE THIS to a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# Initial admin account (created on first start if no users exist)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# ---- Vintage Story server defaults ----
# Version to run by default (can be changed in the UI)
VS_VERSION=1.22.3
# Release channel: stable or unstable
VS_CHANNEL=stable
# Public game port players connect to (TCP+UDP)
VS_GAME_PORT=42420

# ---- Docker / storage paths ----
# ABSOLUTE path on the DOCKER HOST where server data (world, config, mods) lives.
# This must be a host path because the manager tells the Docker daemon to mount it
# into the game container. On your Ubuntu server, e.g. /opt/vsmanager/data
HOST_DATA_DIR=/opt/vsmanager/data
# ABSOLUTE path on the DOCKER HOST where downloaded game versions are cached.
HOST_GAME_DIR=/opt/vsmanager/versions

# Name of the game server container the manager creates/controls
VS_CONTAINER_NAME=vs-server
# Image built for the game server (see vs-server/Dockerfile)
VS_SERVER_IMAGE=vsmanager-vs-server:latest
# Docker network the game container joins (created by docker-compose)
VS_NETWORK=vsmanager_default
